# AI Threat Modeler — environment variables
# Copy this file to .env and fill in real values.

# REQUIRED IN PRODUCTION
# JWT signing secret. Used to mint and verify the auth tokens stored in
# localStorage by the frontend. The backend will refuse to boot in
# NODE_ENV=production without this. Generate a strong value with:
#   openssl rand -hex 32
JWT_SECRET=

# Frontend -> backend URL (browser-side). Defaults to http://localhost:3001/api
# in compose.
NEXT_PUBLIC_API_URL=http://localhost:3001/api

# Optional: container UID/GID for bind-mounted volumes.
UID=502
GID=502
